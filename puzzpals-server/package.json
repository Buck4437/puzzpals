{
  "name": "puzzpals-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.12.0 <25"
  },
  "scripts": {
    "build:models": "cd ../packages/puzzle-models && npm run build",
    "build:parser": "cd ../packages/puzzle-parser && npm run build",
    "watch:models": "cd ../packages/puzzle-models && npm run watch",
    "watch:parser": "cd ../packages/puzzle-parser && npm run watch",
    "build": "npm run build:models && npm run build:parser && tsc -b",
    "start": "node dist/bin/www.js",
    "dev": "npm run build:models && npm run build:parser && npm run watch:models & npm run watch:parser & tsx watch ./src/bin/www.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@puzzpals/puzzle-models": "0.0.0",
    "@puzzpals/puzzle-parser": "0.0.0",
    "cookie-parser": "~1.4.7",
    "cors": "^2.8.6",
    "debug": "~4.4.3",
    "dotenv": "^17.3.1",
    "express": "~5.1.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "morgan": "~1.10.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.1.0",
    "eslint-plugin-n": "^17.24.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
