{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    // For nodejs:
    "lib": ["esnext"],
    "types": ["node"]
    // and npm install -D @types/node
  },
  "include": ["src/**/*"],
  "exclude": ["**/__mocks__", "**/__tests__", "node_modules", "dist"]
}
