{
  "name": "puzzpals-client-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build:models": "cd ../packages/puzzle-models && npm run build",
    "build:parser": "cd ../packages/puzzle-parser && npm run build",
    "watch:models": "cd ../packages/puzzle-models && npm run watch",
    "watch:parser": "cd ../packages/puzzle-parser && npm run watch",
    "watch:models:logs": "tail -f ../puzzle-models-watch.log",
    "watch:parser:logs": "tail -f ../puzzle-parser-watch.log",
    "dev": "npm run build:models && npm run build:parser && (npm run watch:models > ../puzzle-models-watch.log 2>&1 &) && (npm run watch:parser > ../puzzle-parser-watch.log 2>&1 &) && vite",
    "build": "npm run build:models && npm run build:parser && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest run",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "@puzzpals/puzzle-models": "0.0.0",
    "axios": "^1.13.6",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.10",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "~1.51.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.51.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
